{
    "name": "@symflow/core",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./engine": "./src/engine/index.ts",
        "./subject": "./src/subject/index.ts",
        "./yaml": "./src/yaml/index.ts",
        "./json": "./src/json/index.ts",
        "./typescript": "./src/typescript/index.ts",
        "./types": "./src/types/index.ts",
        "./react-flow": "./src/adapters/react-flow/index.ts"
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "publishConfig": {
        "access": "public",
        "main": "./dist/index.cjs",
        "module": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "require": "./dist/index.cjs"
            },
            "./engine": {
                "types": "./dist/engine.d.ts",
                "import": "./dist/engine.js",
                "require": "./dist/engine.cjs"
            },
            "./subject": {
                "types": "./dist/subject.d.ts",
                "import": "./dist/subject.js",
                "require": "./dist/subject.cjs"
            },
            "./yaml": {
                "types": "./dist/yaml.d.ts",
                "import": "./dist/yaml.js",
                "require": "./dist/yaml.cjs"
            },
            "./json": {
                "types": "./dist/json.d.ts",
                "import": "./dist/json.js",
                "require": "./dist/json.cjs"
            },
            "./typescript": {
                "types": "./dist/typescript.d.ts",
                "import": "./dist/typescript.js",
                "require": "./dist/typescript.cjs"
            },
            "./types": {
                "types": "./dist/types.d.ts",
                "import": "./dist/types.js",
                "require": "./dist/types.cjs"
            },
            "./react-flow": {
                "types": "./dist/react-flow.d.ts",
                "import": "./dist/react-flow.js",
                "require": "./dist/react-flow.cjs"
            }
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "peerDependencies": {
        "@xyflow/react": "^12.10.2"
    },
    "peerDependenciesMeta": {
        "@xyflow/react": {
            "optional": true
        }
    },
    "dependencies": {
        "js-yaml": "^4.1.1"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@xyflow/react": "^12.10.2",
        "tsup": "^8.3.5",
        "typescript": "^5.9.3"
    }
}
