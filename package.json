{
    "name": "symflowbuilder",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,css,md,yaml,yml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@auth/prisma-adapter": "^2.11.1",
        "@hookform/resolvers": "^5.2.2",
        "@prisma/client": "^6.19.3",
        "@xyflow/react": "^12.10.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "framer-motion": "^12.38.0",
        "js-yaml": "^4.1.1",
        "lucide-react": "^1.8.0",
        "next": "16.2.3",
        "next-auth": "^5.0.0-beta.30",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.72.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "use-debounce": "^10.1.1",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "eslint": "^9",
        "eslint-config-next": "16.2.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.2",
        "prisma": "^6.19.3",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
