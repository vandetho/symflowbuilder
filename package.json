{
    "name": "symflowbuilder",
    "version": "1.24.0",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "prisma:generate": "pnpm --filter @symflowbuilder/db prisma:generate",
        "prisma:migrate": "pnpm --filter @symflowbuilder/db prisma:migrate",
        "prisma:studio": "pnpm --filter @symflowbuilder/db prisma:studio",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,css,md,yaml,yml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@auth/prisma-adapter": "^2.11.2",
        "@hookform/resolvers": "^5.2.2",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@symflow/core": "workspace:*",
        "@symflowbuilder/db": "workspace:*",
        "@tanstack/react-hotkeys": "^0.9.1",
        "@xyflow/react": "^12.10.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.8.0",
        "next": "^16.2.4",
        "next-auth": "^5.0.0-beta.30",
        "react": "19.2.4",
        "react-color": "^2.19.3",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.72.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "use-debounce": "^10.1.1",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@types/node": "^20.19.39",
        "@types/react": "^19.2.14",
        "@types/react-color": "^3.0.13",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "eslint": "^9.39.4",
        "eslint-config-next": "16.2.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "tailwindcss": "^4",
        "typescript": "^5.9.3"
    }
}
